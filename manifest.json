{
    "name": "Misinformation Detector",
    "description": "Check for misinformation on known news sites",
    "version": "1.0",
    "permissions": [
        "activeTab"
    ],
    "web_accessible_resources": [
      {
      "resources": ["data/mbfc_raw.csv"],
      "matches": ["<all_urls>"]
      }
    ],
    "manifest_version": 3,
    "action": {
      "default_popup": "hello.html",
      "default_icon": "icon128.png"
    }
  }